# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# OneSignal REST API Key (Settings → Keys & IDs in OneSignal dashboard)
# Used by scripts/send-notification.js to send push notifications.
ONESIGNAL_REST_API_KEY=

# ─── Reddit Link Prospector ──────────────────────────────────────────
# See scripts/REDDIT_PROSPECTOR_SETUP.md for step-by-step setup.

# Reddit app credentials (reddit.com/prefs/apps → create script-type app)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Gmail SMTP (use an App Password, not your real Gmail password)
# Create at: myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=
RECIPIENT_EMAIL=

# Anthropic API key (optional — enables AI-drafted comments)
# Get at: console.anthropic.com
ANTHROPIC_API_KEY=
